{
  "name": "pi-mcp-adapter",
  "version": "2.11.0",
  "description": "MCP (Model Context Protocol) adapter extension for Pi coding agent",
  "type": "module",
  "license": "MIT",
  "author": "Nico Bailon",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "pi-mcp-adapter": "cli.js"
  },
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:oauth-provider": "node --import tsx --test mcp-oauth-provider.test.ts",
    "bench:import": "node scripts/bench-import.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicobailon/pi-mcp-adapter.git"
  },
  "keywords": [
    "pi-package",
    "pi",
    "mcp",
    "model-context-protocol",
    "ai",
    "coding-agent",
    "extension",
    "claude",
    "llm"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ],
    "video": "https://github.com/nicobailon/pi-mcp-adapter/raw/refs/heads/main/pi-mcp.mp4"
  },
  "files": [
    "cli.js",
    "dist",
    "banner.png",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "@modelcontextprotocol/ext-apps": "^1.2.2",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "open": "^10.2.0",
    "recheck": "^4.5.0",
    "typebox": "^1.1.24",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.1",
    "@types/bun": "^1.0.0",
    "@types/node": "^20.0.0",
    "@types/open": "^6.2.1",
    "tsdown": "^0.22.13",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
